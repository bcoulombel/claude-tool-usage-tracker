{
  "description": "Append every Skill and Task tool call to a local JSONL log.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/log-tool-usage.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
