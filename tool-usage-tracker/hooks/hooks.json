{
  "description": "Append every tool call to a local JSONL log. Reports filter to Skill/Agent at query time.",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/log-tool-usage.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
